# Production Environment Variables Example
# Copy to .env.production and update with real values

# API Configuration
REACT_APP_API_URL=https://api.junago.com/v1
REACT_APP_ENVIRONMENT=production
REACT_APP_VERSION=1.0.0

# Security
REACT_APP_ENABLE_DEMO_MODE=false

# Performance
GENERATE_SOURCEMAP=false
REACT_APP_ENABLE_ANALYTICS=true

# Monitoring (добавить реальные значения при деплое)
# REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# REACT_APP_GA_ID=GA-XXXXXXXXX-X

# Features
REACT_APP_ENABLE_DEV_TOOLS=false
REACT_APP_ENABLE_LOGGING=false 